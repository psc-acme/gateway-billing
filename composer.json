{
    "name": "psc-acme/gateway-billing",
    "description": "Package gateway-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\GatewayBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/process": "^7.0",
        "firebase/php-jwt": "^6.0",
        "league/csv": "^9.0",
        "symfony/mailer": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0",
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}